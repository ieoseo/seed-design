  "shadow": {
    "light": {
      "1": "0 1px 2px rgba(0,0,0,0.04), 0 2px 8px rgba(23,23,23,0.06)",
      "2": "0 4px 14px rgba(23,23,23,0.09), 0 1px 2px rgba(0,0,0,0.04)",
      "3": "0 14px 34px rgba(23,23,23,0.14), 0 2px 6px rgba(0,0,0,0.05)"
    },
    "dark": {
      "1": "0 1px 2px rgba(0,0,0,0.30)",
      "2": "0 6px 18px rgba(0,0,0,0.45)",
      "3": "0 16px 40px rgba(0,0,0,0.55)"
    }
  },
  "components": {
    "$note": "컴포넌트 디자인 스펙(플랫폼 중립). 수치는 client DkButton 권위값. 색은 scheme 키 참조(#hex 는 리터럴, transparent 는 투명). generator 가 Dart(SeedButton)·CSS(.btn) 로 변환.",
    "button": {
      "weight": 600,
      "letterSpacingEm": 0.0096,
      "pressTranslateY": 1,
      "borderWidth": 1.5,
      "sizes": {
        "sm": { "height": 40, "padX": 14, "padY": 8, "fontSize": 13, "radius": 10, "gap": 6 },
        "md": { "height": 50, "padX": 18, "padY": 13, "fontSize": 15, "radius": 14, "gap": 7 },
        "lg": { "height": 56, "padX": 22, "padY": 16, "fontSize": 16, "radius": 16, "gap": 8 }
      },
      "variants": {
        "primary": { "bg": "primary", "fg": "#FFFFFF", "border": "transparent" },
        "neutral": { "bg": "fg", "fg": "bg", "border": "transparent" },
        "outline": { "bg": "transparent", "fg": "fg", "border": "border" },
        "subtle": { "bg": "primarySubtle", "fg": "primary", "border": "transparent" },
        "ghost": { "bg": "transparent", "fg": "fgMuted", "border": "transparent" },
        "danger": { "bg": "dangerSubtle", "fg": "danger", "border": "transparent" }
      }
    },
    "badge": {
      "padX": 9,
      "padY": 3,
      "radius": 8,
      "fontSize": 12,
      "weight": 600,
      "letterSpacing": 0.12,
      "lineHeight": 1.5,
      "gap": 4,
      "tones": {
        "neutral": { "bg": "bgPress", "fg": "fgMuted" },
        "primary": { "bg": "primarySubtle", "fg": "primary" },
        "success": { "bg": "successSubtle", "fg": "successFg" },
        "warning": { "bg": "warningSubtle", "fg": "warningFg" },
        "danger": { "bg": "dangerSubtle", "fg": "danger" },
        "info": { "bg": "infoSubtle", "fg": "infoFg" },
        "violet": { "bg": "violetSubtle", "fg": "violetFg" }
      }
    },
    "card": {
      "padding": 18,
      "pressScale": 0.985,
      "pressDurationMs": 120
    },
    "segmented": {
      "pad": 3,
      "radius": 12,
      "thumbRadius": 9,
      "tabPadX": 14,
      "tabPadY": 8,
      "fontSize": 14,
      "weight": 600,
      "thumbDurationMs": 260,
      "textDurationMs": 200
    },
    "chip": {
      "padX": 14,
      "padY": 9,
      "radius": 10,
      "fontSize": 14,
      "weight": 600,
      "borderWidth": 1.5,
      "gap": 6,
      "on": { "bg": "primarySubtle", "fg": "primary", "border": "primary" },
      "off": { "bg": "bg", "fg": "fgMuted", "border": "border" }
    }
  }
}
