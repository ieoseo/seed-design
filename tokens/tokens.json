      "fgDisabled": "#EBEBF54D",
      "border": "#FFFFFF1F",
      "borderSubtle": "#FFFFFF12",
      "borderStrong": "#FFFFFF42",
      "overlay": "#00000099",
      "success": "#2BD968",
