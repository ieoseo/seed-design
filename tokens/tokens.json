{
  "$meta": {
    "name": "ieoseo seed tokens",
    "source": "client DkTokens (client/lib/theme/tokens.dart) + docs/01-디자인분석/디자인시스템-토큰.md",
    "note": "primaryHover/primarySubtle 는 generator 가 primary 에서 sRGB lerp(_mix) 로 파생한다. 색은 #RRGGBB 또는 #RRGGBBAA(alpha last)."
  },
  "brand": {
    "primary": "#0066FF"
  },
  "radius": {
    "base": 24,
    "lg": 32,
    "chip": 8,
    "button": 14
  },
  "type": {
    "sans": "Pretendard",
    "brand": "Wanted Sans",
    "baseSize": 15
  },
  "motion": {
    "easing": {
      "production": "cubic-bezier(0.4, 0, 0.2, 1)",
      "spring": "cubic-bezier(0.34, 1.3, 0.64, 1)"
    },
    "duration": {
      "instant": "100ms",
      "transition": "230ms",
      "overlay": "320ms",
      "fill": "600ms"
    }
  },
  "hue": {
    "blue": { "color": "#0066FF", "subtle": "#0066FF1A" },
    "violet": { "color": "#6541F2", "subtle": "#6541F21A" },
    "orange": { "color": "#FF9200", "subtle": "#FF92001F" },
    "green": { "color": "#00BF40", "subtle": "#00BF401F" },
    "sky": { "color": "#00AEFF", "subtle": "#00AEFF1F" },
    "cool": { "color": "#70737C", "subtle": "#70737C1F" },
    "red": { "color": "#FF4242", "subtle": "#FF42421A" }
  },
  "source": {
    "app": "#0066FF",
    "google": "#34A853",
    "apple": "#111111",
    "notion": "#7B61FF",
    "kakao": "#FEE500"
  },
  "color": {
    "light": {
      "bg": "#FFFFFF",
      "bgSubtle": "#F7F7F8",
