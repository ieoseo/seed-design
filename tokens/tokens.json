{
  "$meta": {
    "name": "ieoseo seed tokens",
    "source": "client DkTokens (client/lib/theme/tokens.dart) + docs/01-디자인분석/디자인시스템-토큰.md",
    "note": "primaryHover/primarySubtle 는 generator 가 primary 에서 sRGB lerp(_mix) 로 파생한다. 색은 #RRGGBB 또는 #RRGGBBAA(alpha last)."
  },
  "brand": {
    "primary": "#0066FF"
  },
