      "fgMuted": "#2E2F33DC",
      "fgSubtle": "#37383C94",
      "fgDisabled": "#37383C4D",
      "border": "#70737C38",
      "borderSubtle": "#70737C1F",
      "borderStrong": "#70737C66",
      "overlay": "#1717196B",
